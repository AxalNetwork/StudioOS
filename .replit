modules = ["web", "nodejs-20", "ruby-3.2", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python -m uvicorn backend.app.main:app --host localhost --port 8000 & cd /home/runner/workspace/frontend && npx vite --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "-c", "cd frontend && npx vite build && cp -r dist ../static"]
publicDir = "_site"
run = ["bash", "-c", "cd /home/runner/workspace && python -m uvicorn backend.app.main:app --host 0.0.0.0 --port 5000"]

[userenv]

[userenv.shared]
GOOGLE_REDIRECT_URI = "https://developers.google.com/oauthplayground"
GITHUB_ACCESS_TOKEN = "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"
GITHUB_REPO_OWNER = "AxalNetwork"
GITHUB_REPO_NAME = "StudioOS"
