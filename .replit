modules = ["web", "nodejs-20", "ruby-3.2", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cacert", "cargo", "grpc", "libffi", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Code Repository"

[[workflows.workflow]]
name = "Code Repository"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'This project runs on GitHub Pages (frontend) and Cloudflare Workers (backend). Replit is used as a code editor only.'"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "build-deploy.sh"]
run = ["bash", "run-deploy.sh"]

[userenv]

