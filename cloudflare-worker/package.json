{
  "name": "studioos-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config ../wrangler.toml",
    "deploy": "wrangler deploy --config ../wrangler.toml",
    "db:create": "wrangler d1 create studioos-db",
    "db:schema": "wrangler d1 execute studioos-db --config ../wrangler.toml --file=sql/schema.sql",
    "db:schema:remote": "wrangler d1 execute studioos-db --config ../wrangler.toml --remote --file=sql/schema.sql"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "jose": "^5.6.0",
    "mimetext": "^3.0.28",
    "otpauth": "^9.3.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
