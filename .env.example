# =============================================================================
# Axal StudioOS – Environment Variable Template
# =============================================================================
# Copy this file to `.env` for local development of the FastAPI backend, and
# set the Cloudflare Worker secrets via `wrangler secret put <NAME>`.
#
# DO NOT commit `.env`. Only `.env.example` should live in git.
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare account (used by Wrangler / GitHub Actions, not by app code)
# -----------------------------------------------------------------------------
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Auth / sessions
# -----------------------------------------------------------------------------
# 64+ random chars. Used to sign JWTs issued by the Worker.
#   openssl rand -hex 48
JWT_SECRET=

# Replit Auth (for the Replit-hosted FastAPI dev backend only)
REPLIT_AUTH_SECRET=

# -----------------------------------------------------------------------------
# Database (Replit dev backend)
# -----------------------------------------------------------------------------
# Auto-provisioned by Replit. The Worker uses Cloudflare D1 instead (configured
# in wrangler.toml as the `DB` binding).
DATABASE_URL=

# -----------------------------------------------------------------------------
# Email (Gmail OAuth via Workers)
# -----------------------------------------------------------------------------
# Create OAuth client at https://console.cloud.google.com/apis/credentials
# Then run scripts/get-gmail-refresh-token.sh (see cloudflare-worker/EMAIL-SETUP.md).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Payments / banking (Stripe Atlas for spin-out incorporation)
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_ATLAS_API_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# KYC / compliance providers
# -----------------------------------------------------------------------------
# Sumsub: https://cockpit.sumsub.com/checkus#/devSpace/appTokens
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI providers (Worker uses Workers AI by default; OpenAI is optional fallback)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Default Workers AI model used for partner/deal scoring
AI_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct
AI_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5

# -----------------------------------------------------------------------------
# Bot / abuse protection
# -----------------------------------------------------------------------------
# https://dash.cloudflare.com → Turnstile → Add site
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# GitHub integration (issue sync, activity feed)
# -----------------------------------------------------------------------------
# Fine-grained PAT with `Issues: Read & write` on the StudioOS repo.
GITHUB_ACCESS_TOKEN=
GITHUB_REPO_OWNER=AxalNetwork
GITHUB_REPO_NAME=StudioOS

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST=30

# -----------------------------------------------------------------------------
# Cloudflare bindings (informational – actual values live in wrangler.toml)
# -----------------------------------------------------------------------------
D1_DATABASE_NAME=studioos-db
QUEUE_NAME=studioos-queue
KV_TOKENS_NAMESPACE=TOKENS
KV_RATE_LIMITS_NAMESPACE=RATE_LIMITS

# -----------------------------------------------------------------------------
# Optional: deploy notifications
# -----------------------------------------------------------------------------
SLACK_DEPLOY_WEBHOOK_URL=
