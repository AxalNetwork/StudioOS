# =============================================================================
# Axal StudioOS – Frontend Environment Template
# =============================================================================
# Copy to `frontend/.env.local` for local dev. Vite injects only variables
# prefixed with `VITE_` into the client bundle. NEVER put secrets here —
# anything in this file is shipped to every browser that loads the app.
# =============================================================================

# Backend API base URL (Cloudflare Worker in production, FastAPI in dev).
VITE_API_URL=https://studioos.guillaumelauzier.workers.dev

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (bot protection)
# -----------------------------------------------------------------------------
# PUBLIC site key — safe to expose. Get from:
#   https://dash.cloudflare.com → Turnstile → your widget → "Site Key"
# Leave blank to disable the widget; backend verifier also fails-open when its
# matching secret is unset.
VITE_TURNSTILE_SITE_KEY=
