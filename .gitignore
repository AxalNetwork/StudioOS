# =============================================================================
# Axal StudioOS – .gitignore
# =============================================================================

# ---- Environment / secrets ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- Node / frontend ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/

# Vite / build output (frontend builds to docs/ which IS committed
# because GitHub Pages serves from there; uncomment if you change that).
# docs/
.vite/

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
.venv/
venv/
.pythonlibs/

# ---- Cloudflare / Wrangler ----
.wrangler/
.dev.vars
worker-configuration.d.ts

# ---- Editors / OS ----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Replit local state ----
.cache/
.config/
.upm/
.local/
.agents/

# ---- Logs / tmp ----
*.log
/tmp/
.tmp/
